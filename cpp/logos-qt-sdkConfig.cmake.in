@PACKAGE_INIT@

# logos-qt-sdkConfig.cmake — consumed by `find_package(logos-qt-sdk)`.
# Re-resolves the SDK's dependencies (Qt + logos-protocol, which itself
# propagates Boost / OpenSSL / nlohmann_json) before importing the target.

include(CMakeFindDependencyMacro)

find_dependency(Qt6 REQUIRED COMPONENTS Core RemoteObjects)
find_dependency(logos-protocol REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/logos-qt-sdkTargets.cmake")

check_required_components(logos-qt-sdk)
